@"Round-trips a small JSON object: parse -> extract -> re-encode."
agent extract_name(payload: unknown) -> string {
  match (payload) {
    case record({ name = string(n) }) => { n }
    case _ => { "unknown" }
  }
}

agent main() -> string {
  let original = "{\"name\":\"alice\",\"age\":30}"
  let parsed = json_parse(text = original)
  let name = extract_name(payload = parsed)
  let echoed = json_stringify(value = parsed)
  f"name=${name}; echo=${echoed}"
}
