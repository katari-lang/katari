@"Adds two integers."
agent add_them(x: integer, y: integer) -> integer { x + y }

@"Pulls metadata from a top-level agent and a local closure."
agent main() -> string {
  @"Local helper agent."
  agent local_bar(s: string) -> string { s }

  let mg = get_metadata(value = add_them)
  let ml = get_metadata(value = local_bar)
  match (mg) {
    case agent_metadata(name = ng, id = ig, description = _, input = _, output = _) => {
      match (ml) {
        case agent_metadata(name = nl, id = il, description = _, input = _, output = _) => {
          ng ++ "|" ++ ig ++ "|" ++ nl ++ "|" ++ il
        }
      }
    }
  }
}
