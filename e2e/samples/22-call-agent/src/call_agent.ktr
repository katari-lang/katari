@"Returns a greeting string."
agent greeter(name: string) -> string {
  f"hello, ${name}"
}

@"Invoke the greeter dynamically with a runtime-built args record. call_agent takes the callable VALUE (greeter) + a dynamic args record, validating the args against greeter's input schema; bad args raise error_invalid_argument, which the handle scope catches and turns into a diagnostic string."
agent try_call(args: {}) -> string {
  handle {
    request error_invalid_argument(message: string) {
      break f"err: ${message}"
    }
  }
  match (call_agent[string, pure](target = greeter, args = args)) {
    case string(s) => { s }
    case _ => { "non-string return" }
  }
}

@"Demonstrates dynamic dispatch + per-call schema validation via call_agent."
agent main() -> string {
  let ok_value = try_call(args = { name = "alice" })
  let err_value = try_call(args = { wrong = "oops" })
  f"ok=${ok_value}; bad=${err_value}"
}
