@"Greet someone. suffix is optional (defaults to a bang) and may be omitted."
agent greet(name: string, suffix: string = "!") -> string {
  f"hi ${name}${suffix}"
}

@"Add by to n. by is optional (defaults to 1) and may be omitted."
agent bump(n: integer, by: integer = 1) -> integer {
  n + by
}

@"Omitting an optional argument fills the default; passing it overrides."
agent main() -> string {
  let a = greet(name = "ada")
  let b = greet(name = "bob", suffix = "?")
  let c = bump(n = 10)
  let d = bump(n = 10, by = 5)
  f"${a} | ${b} | ${to_string(value = c)} | ${to_string(value = d)}"
}
