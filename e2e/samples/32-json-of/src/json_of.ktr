@"The json bridge: json.of reflects a dynamic (untagged) value into the json union; json.get / json.at navigate it with the json type preserved; json.to_object unwraps a json object back to a plain object value (the inverse of of). Together they let you build and read json entirely in Katari."
agent main() -> string {
  let dynamic = { items = [1, 2, 3] }
  let encoded = json.of(value = dynamic)
  let text = json.stringify(value = encoded)
  let second = match (json.at(value = json.get(value = encoded, key = "items"), index = 1)) {
    case json_integer(value = v) => { to_string(value = v) }
    case _ => { "?" }
  }
  // round-trip: json -> plain object value -> json -> text (should equal `text`)
  let restringified = json.stringify(value = json.of(value = json.to_object(value = encoded)))
  f"${text}|${second}|${restringified}"
}
