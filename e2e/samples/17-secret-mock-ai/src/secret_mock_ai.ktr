@"Mock HTTP request. Sidecar echoes the received URL plus the secret auth header so the e2e test can verify the value crossed the boundary intact."
external http_request(url: string, auth: secret) -> string from "FFI:secret_mock_ai.http_request"

@"Reads MOCK_KEY from the env store as a secret, hands it to http_request as the auth header, returns the sidecar's echoed body. Catches `env_not_found` locally so a missing key surfaces as a normal string result rather than a snapshot error."
agent main() -> string {
  handle {
    request env_not_found(env_key: string) {
      break f"env missing: ${env_key}"
    }
  }
  let key = get_secret_env(key = "MOCK_KEY")
  http_request(url = "https://example.com/echo", auth = key)
}
