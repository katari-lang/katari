@"Dispatch a LOCAL closure dynamically with a runtime-built args record. call_agent takes the closure VALUE directly + validates the args against the closure's input schema (read from its content-ref blob) before invoking it: the dynamic-dispatch round-trip for a closure."
agent main() -> string {
  @"A local closure, invoked dynamically via call_agent."
  agent local_greet(name: string) -> string { f"hi ${name}" }

  use handler {
    request error_invalid_argument(message: string) { break f"err: ${message}" }
  }
  call_agent[string, pure](target = local_greet, args = { name = "bob" })
}
