// Admin UI test playground.
//
// Each agent exercises a different type / SchemaForm / ValueViewer shape.
// Apply this snapshot, then click through them in /admin.
//
// Organised by type category so reviewers can verify coverage at a glance.

// ─── Primitives ─────────────────────────────────────────────────────

@"String input and output."
agent prim_string(text: string) -> string { f"echo: ${text}" }

@"Integer input. Returns n * 2."
agent prim_integer(n: integer) -> integer { n + n }

@"Number (float) input. Returns value / 2."
agent prim_number(value: number) -> number { value / 2 }

@"Boolean input. Returns the inverse."
agent prim_boolean(flag: boolean) -> boolean { not(value = flag) }

@"Null-returning agent. Input is ignored."
agent prim_null(ignored: string) -> null { null }

// ─── Literal types ──────────────────────────────────────────────────

@"String literal union → EnumField dropdown."
agent literal_string_union(color: "red" | "green" | "blue") -> string {
  f"painted ${color}"
}

// ─── Multi-parameter ────────────────────────────────────────────────

@"Multiple params with per-parameter descriptions."
agent multi_param(
  @"The greeter's name."
  name: string,
  @"Greeting style."
  style: "casual" | "formal"
) -> string {
  match (style) {
    case "casual" => { f"hey ${name}!" }
    case _        => { f"Good day, ${name}." }
  }
}

// ─── Data constructors ──────────────────────────────────────────────

@"A 2-D point."
data point(
  @"Horizontal coordinate."
  x: integer,
  @"Vertical coordinate."
  y: integer
)

@"Takes a data ctor input. ObjectField with auto-hidden $constructor."
agent data_input(@"point of input" p: point) -> integer {
  match (p) {
    case point(x = xv, y = yv) => { xv + yv }
  }
}

@"Returns a data ctor value."
data ok(n: integer)
@"Error variant."
data err(message: string)

@"Returns a data ctor. Tests ValueViewer $constructor rendering."
agent data_output(n: integer) -> point { point(x = n, y = n * 2) }

// ─── Tagged union (data ctor union) ─────────────────────────────────

@"Tagged-union INPUT. Tests UnionField dropdown on invoke form."
agent union_input(r: ok | err) -> string {
  match (r) {
    case ok(n = v) => { f"ok: ${to_string(value = v)}" }
    case err(message = m) => { f"err: ${m}" }
  }
}

@"Tagged-union RETURN. Tests ValueViewer union rendering."
agent union_output(should_fail: boolean) -> ok | err {
  match (should_fail) {
    case true => { err(message = "intentional failure") }
    case _    => { ok(n = 42) }
  }
}

// ─── Tuple ──────────────────────────────────────────────────────────

@"2-tuple input. Tests TupleField with mixed element types."
agent tuple_input(t: [integer, string]) -> string {
  match (t) {
    case [0, s] => { f"zero with ${s}" }
    case [n, s] => { f"${to_string(value = n)} with ${s}" }
  }
}

@"3-tuple with nested data. Tests nested tuple rendering."
agent tuple_nested(t: [point, string, boolean]) -> string {
  match (t) {
    case [point(x = xv, y = yv), label, flag] => {
      f"(${to_string(value = xv)},${to_string(value = yv)}) ${label} ${to_string(value = flag)}"
    }
  }
}

// ─── Array ──────────────────────────────────────────────────────────

@"Array of integers. Tests ArrayField add/remove."
agent array_length_int(arr: array[integer]) -> integer {
  array.length(array = arr)
}

@"Array of data ctors. Tests nested array + data ctor input."
agent array_of_points(points: array[point]) -> integer {
  array.length(array = points)
}

// ─── Record ─────────────────────────────────────────────────────────

@"Record (dynamic key-value map). Tests DynamicKeyValueEditor."
agent record_echo(r: record) -> record { r }

// (Katari doesn't have anonymous object literals — named fields use data ctors)

// ─── Nested combinations ────────────────────────────────────────────

@"Array of unions. Tests ArrayField + UnionField nesting."
agent nested_array_union(items: array[ok | err]) -> integer {
  array.length(array = items)
}

@"Record of arrays. Tests DynamicKeyValueEditor + ArrayField nesting."
agent nested_record_array(groups: record) -> record { groups }

@"Echo of Array"
agent echo_array(ints: array[integer]) -> array[integer] { ints }

@"Union containing tuple. Deep nesting test."
data wrapped_pair(pair: [integer, string])
data wrapped_single(value: integer)

agent nested_union_tuple(input: wrapped_pair | wrapped_single) -> string {
  match (input) {
    case wrapped_pair(pair = t) => {
      match (t) {
        case [n, s] => { f"pair: ${to_string(value = n)} ${s}" }
      }
    }
    case wrapped_single(value = v) => { f"single: ${to_string(value = v)}" }
  }
}

// ─── Escalation ─────────────────────────────────────────────────────

@"Answerable request. Tests escalation answer form."
request ask(@"Question for the operator." prompt: string) -> string

@"Calls ask(). Creates an open escalation."
agent escalation_ask() -> string with ask {
  let name = ask(prompt = "What's your name?")
  f"hello, ${name}"
}

@"Boolean request. Tests BooleanField in escalation answer."
request confirm(@"Yes/no question." prompt: string) -> boolean

@"Calls confirm(). Tests boolean escalation."
agent escalation_confirm() -> string with confirm {
  match (confirm(prompt = "Proceed?")) {
    case true => { "proceeded" }
    case _    => { "user said no" }
  }
}

@"Never-returning request. Tests the never escalation UX."
request fatal(reason: string) -> never

@"Raises fatal. Shows never-type escalation page."
agent escalation_never() -> string with fatal {
  fatal(reason = "this can never receive an answer")
  "unreachable"
}

// ─── Delegation tree demos ──────────────────────────────────────────

@"Sleep for ms milliseconds on the host side."
external sleep_ms(ms: integer) -> null from "FFI:playground.sleep_ms"

@"Sequential sleeps. Tree shows one ext node at a time."
agent tree_sequential() -> string {
  sleep_ms(ms = 2000)
  sleep_ms(ms = 2000)
  sleep_ms(ms = 2000)
  "done"
}

@"Parallel sleeps. Tree shows three ext nodes simultaneously."
agent tree_parallel() -> string {
  let _ = parallel [sleep_ms(ms = 3000), sleep_ms(ms = 5000), sleep_ms(ms = 7000)]
  "done"
}

@"FFI-side fan out. Tests ext-spawned child delegations in tree."
external fan_out(callback: agent () -> string, count: integer) -> integer from "FFI:playground.fan_out"

@"Slow child for fan_out."
agent slow_child() -> string {
  sleep_ms(ms = 3000)
  "ok"
}

@"Fans out three slow_child via ext. Tests FFI delegation tree."
agent tree_ffi_fanout() -> integer {
  fan_out(callback = slow_child, count = 3)
}

// ─── Entry ──────────────────────────────────────────────────────────

@"Default entry point."
agent main() -> string { "playground ready" }
