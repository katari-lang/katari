// Admin UI form playground.
//
// Each agent here exercises a different SchemaForm shape. Apply this
// snapshot, then click through them in /admin/.../definitions.

// === Primitives ===

@"Single string param - exercises StringField."
agent echo_string(@"The text to echo back, prefixed with 'echo: '." text: string) -> string { f"echo: ${text}" }

@"Single integer param - exercises NumberField (integer)."
agent double_int(@"Any integer. The result is n + n." n: integer) -> integer { n + n }

@"Single number param - exercises NumberField."
agent halve(@"The number to divide by two." value: number) -> number { value / 2 }

@"Single boolean param - exercises BooleanField (toggle)."
agent flip(@"The flag to invert." flag: boolean) -> boolean { not(value = flag) }

// === Multi-parameter agent (= each parameter independently annotated) ===

@"Greets a person - exercises per-parameter descriptions on the invoke form."
agent greet(
  @"The greeter's name; appears verbatim in the result."
  name: string,
  @"Style of greeting prefix to use."
  style: "casual" | "formal"
) -> string {
  match (style) {
    case "casual" => { f"hey ${name}!" }
    case _        => { f"Good day, ${name}." }
  }
}

// === Data ctor (object form) ===

@"A 2-D point."
data point(
  @"Horizontal coordinate (rightward positive)."
  x: integer,
  @"Vertical coordinate (downward positive)."
  y: integer
)

@"Takes a point - exercises ObjectField with auto-hidden $constructor."
agent point_sum(p: point) -> integer {
  match (p) {
    case point(x = xv, y = yv) => { xv + yv }
  }
}

// === Tuple ===

@"Takes a 2-tuple - exercises TupleField with mixed element types."
agent describe_pair(t: (integer, string)) -> string {
  match (t) {
    case (0, s) => { f"zero with ${s}" }
    case (n, s) => { f"${to_string(value = n)} with ${s}" }
  }
}

// === Data ctor returns (single and tagged-union) ===

@"A success-shaped result."
data ok(n: integer)

@"Builds an ok value - exercises tagged-data return rendering on the Returns card."
agent build_ok(n: integer) -> ok { ok(n = n) }

@"A failure shape."
data err(message: string)

@"Tagged-union ARGUMENT (not return) - tests admin's tagged-union dropdown on the invoke form."
agent describe_result(r: ok | err) -> string {
  match (r) {
    case ok(n = v) => { f"ok: ${to_string(value = v)}" }
    case err(message = m) => { f"err: ${m}" }
  }
}

@"Tagged-union RETURN - exercises bound-pair solver path for union upper bounds."
agent maybe_fail(should_fail: boolean) -> ok | err {
  match (should_fail) {
    case true => { err(message = "intentional failure") }
    case _    => { ok(n = 42) }
  }
}

@"String-literal union - admin should render EnumField (= dropdown of red/green/blue)."
agent paint(color: "red" | "green" | "blue") -> string {
  f"painted ${color}"
}

// === Escalation: regular request ===

@"Operator-answerable prompt."
request ask(@"Question the operator should answer. Free-form text." prompt: string) -> string

@"Calls ask() with no surrounding handler - surfaces as an open escalation in admin."
agent ask_name() -> string with ask {
  let name = ask(prompt = "What's your name?")
  f"hello, ${name}"
}

@"Boolean-returning request - escalation answer form renders a BooleanField toggle."
request confirm(@"Yes/no question to display in the escalation UI." prompt: string) -> boolean

@"Drives one confirm() call."
agent check_proceed() -> string with confirm {
  match (confirm(prompt = "Proceed?")) {
    case true => { "proceeded" }
    case _    => { "user said no" }
  }
}

// === Escalation: never request (tests the never UX) ===

@"A request declared with never. Cannot be answered with a value."
request fatal(reason: string) -> never

@"Raises a never-returning request - escalation page shows the never UX."
agent trigger_never() -> string with fatal {
  fatal(reason = "this demo can never receive a meaningful answer")
  "unreachable"
}

// === Entry ===

@"Default no-arg entry point."
agent main() -> string {
  "playground"
}

// === Tree-view demos (host-side sleep via sidecar) ===
//
// These give the admin's run tree view something visibly in-flight to
// render. `sleep_ms` blocks the ext for the requested duration; the
// agents below combine it with Katari's built-in `par (...)` to get
// parallel delegations under the same root, and with `fan_out` to also
// exercise the FFI-side `katari.delegate` path.

@"Sleep for `ms` milliseconds on the host. Each call shows up as one ext-call node in the run tree for its duration."
external sleep_ms(ms: integer) -> null from "FFI:playground.sleep_ms"

@"Three sequential sleeps. Watch the tree: one ext node appears, finishes, then the next, etc."
agent demo_sequential_sleeps() -> string {
  sleep_ms(ms = 2000)
  sleep_ms(ms = 2000)
  sleep_ms(ms = 2000)
  "three sleeps done"
}

@"Three parallel sleeps via `par (...)`. The tree shows three ext nodes in flight at once under the run root."
agent demo_par_sleeps() -> string {
  let _ = par (sleep_ms(ms = 3000), sleep_ms(ms = 4000), sleep_ms(ms = 5000))
  "three parallel sleeps done"
}

// === FFI-side parallelism (= ext-spawned children) ===
//
// Mostly to exercise the `katari.delegate` path on the sidecar side
// (= ext-spawned child delegations, recorded under the ext call in the
// tree). Pure-Katari `par` above is the cleaner way to fan out; this is
// here to make the FFI code path visible.

@"Fan out `count` parallel copies of `callback` from the ext side. Returns the number of results gathered."
external fan_out(callback: () -> string, count: integer) -> integer from "FFI:playground.fan_out"

@"Small CORE-side agent used as the callback in demo_ffi_fanout."
agent slow_child() -> string {
  sleep_ms(ms = 3000)
  "ok"
}

@"Fans out three slow_child copies via the ext. Tree: fan_out ext call + three CORE-side children running concurrently."
agent demo_ffi_fanout() -> integer {
  fan_out(callback = slow_child, count = 3)
}
