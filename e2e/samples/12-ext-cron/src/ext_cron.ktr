@"Cron-like notification cap. Bumped once each time the ext invokes its callback."
request scheduled() -> null

@"Hand a callback to the host JS. The ext delegates it as a child agent on a tick."
external cron_impl(callback: agent () -> null with scheduled) -> null from "FFI:ext_cron.cron_impl"

@"Inner agent. Bridges the ext's callback delivery into the parent's `scheduled` cap."
agent notify_scheduled() -> null with scheduled {
  scheduled()
}

@"Runs the cron and never returns by itself; the parent's handler `break`s out instead."
agent run() -> integer with scheduled {
  cron_impl(callback = notify_scheduled)
  0
}

@"Returns the number of scheduled() ticks observed before the handler breaks (= 1 for this sample)."
agent main() -> integer {
  handle (var counter = 0) {
    request scheduled() {
      break counter + 1
    }
  }
  run()
}
