agent identity[U](x: U) -> U { x }

@"identity[T] inside a generic agent: its metadata schema resolves T to the caller's concrete type via the ambient substitution."
agent describe[T](x: T) -> string {
  let f = identity[T]
  get_metadata(value = f).input
}

agent main() -> string {
  describe[integer](x = 5)
}
