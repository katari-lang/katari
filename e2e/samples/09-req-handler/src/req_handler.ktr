@"Asks the handler for the next counter value."
request tick() -> integer

@"Drives three ticks under a counter handler and combines them."
agent run() -> integer with tick {
  let a = tick()
  let b = tick()
  let c = tick()
  a + b + c
}

@"Installs a stateful tick handler: each tick() call returns the current counter, then bumps it by one via 'next ... with { counter = ... }'."
agent main() -> integer {
  handle (var counter: integer = 1) {
    request tick() {
      next counter with { counter = counter + 1 }
    }
  }
  run()
}
