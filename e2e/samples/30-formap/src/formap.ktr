@"Map: each next contributes to the output array."
agent double_all(xs: array[integer]) -> array[integer] {
  for (let x in xs) { next x + 10 }
}

@"Parallel map: same shape as sequential, results in source order."
agent par_all(xs: array[integer]) -> array[integer] {
  parallel for (let x in xs) { next x * 2 }
}

@"then(pat) binds the mapped array; here we post-process its length."
agent count_mapped(xs: array[integer]) -> integer {
  for (let x in xs) { next x } then (ys) { array.length(array = ys) }
}

@"break short-circuits the whole loop to the break value (discarding the map)."
agent always_break() -> array[integer] {
  for (let x in [1, 2, 3]) { break [7, 8, 9] }
}

@"A capability the parallel-for bodies escalate to (handled below by an enclosing handle)."
request bump(n: integer) -> integer

@"Parallel for whose bodies each RAISE a request — exercises concurrent escalations bubbling through the for thread to a sequential handle, with each askAck routed back to the right iteration."
agent par_with_effect(xs: array[integer]) -> array[integer] {
  handle (var base = 100) {
    request bump(n: integer) {
      next base + n
    }
  }
  parallel for (let x in xs) { next bump(n = x) }
}

@"a0=11 a2=13 b1=4 c=4 d1=8 e0=101"
agent main() -> string {
  let a = double_all(xs = [1, 2, 3])
  let b = par_all(xs = [1, 2, 3])
  let c = count_mapped(xs = [1, 2, 3, 4])
  let d = always_break()
  let e = par_with_effect(xs = [1, 2, 3])
  f"a0=${to_string(value = array.get(array = a, index = 0))} a2=${to_string(value = array.get(array = a, index = 2))} b1=${to_string(value = array.get(array = b, index = 1))} c=${to_string(value = c)} d1=${to_string(value = array.get(array = d, index = 1))} e0=${to_string(value = array.get(array = e, index = 0))}"
}
