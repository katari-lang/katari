# Server
PORT=3000
# Interface to bind. 0.0.0.0 (all interfaces) is required in a container; use
# 127.0.0.1 to restrict the unauthenticated v0.1 API to loopback.
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development
# Allowed CORS origin(s): * (default) or a comma-separated allowlist. The API is
# currently unauthenticated, so lock this down in any shared deployment.
CORS_ORIGIN=*

# Database — matches compose.yaml. Override the host/port if you map a
# different one via POSTGRES_PORT in Docker Compose.
DATABASE_URL=postgres://katari:katari@localhost:5432/katari

# Encryption key for secret (private) values at rest — REQUIRED (the runtime refuses to boot without it).
# Must be a base64-encoded 32 bytes. Generate your own — do NOT ship a key from version control:
#   openssl rand -base64 32
KATARI_SECRET_KEY=
