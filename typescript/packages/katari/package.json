{
  "name": "@katari-lang/cli",
  "version": "0.1.0-rc5",
  "description": "Katari CLI: a thin Node shim that locates the prebuilt katari binary shipped by @katari-lang/cli-<platform> packages and forwards arguments. Installs the `katari` executable.",
  "license": "MIT",
  "author": "yukikurage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/katari-lang/katari.git",
    "directory": "typescript/packages/katari"
  },
  "homepage": "https://github.com/katari-lang/katari#readme",
  "bugs": "https://github.com/katari-lang/katari/issues",
  "type": "module",
  "bin": {
    "katari": "bin/katari.mjs"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@katari-lang/bundle": "workspace:*"
  }
}
