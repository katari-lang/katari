{
  "name": "katari-vscode",
  "displayName": "Katari",
  "description": "Syntax highlighting and language support for the Katari language.",
  "version": "0.1.0-rc5",
  "private": true,
  "license": "MIT",
  "publisher": "yukikurage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/katari-lang/katari.git",
    "directory": "typescript/packages/katari-vscode"
  },
  "bugs": "https://github.com/katari-lang/katari/issues",
  "homepage": "https://github.com/katari-lang/katari#readme",
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "katari",
        "aliases": [
          "Katari",
          "katari"
        ],
        "extensions": [
          ".ktr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "katari",
        "scopeName": "source.katari",
        "path": "./syntaxes/katari.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Katari",
      "properties": {
        "katari.server.path": {
          "type": "string",
          "default": "katari-lsp",
          "description": "Path to the katari-lsp executable (looked up on PATH if not absolute)."
        },
        "katari.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra command-line arguments passed to katari-lsp (useful for verbose logging flags during LSP development)."
        }
      }
    }
  },
  "exports": {
    "./grammar": "./syntaxes/katari.tmLanguage.json",
    "./language-configuration": "./language-configuration.json"
  },
  "scripts": {
    "build": "node scripts/bundle.mjs",
    "build:typecheck": "tsc -p . --noEmit",
    "vscode:prepublish": "NODE_ENV=production node scripts/bundle.mjs",
    "package": "vsce package --no-dependencies --out katari-vscode.vsix",
    "test": "node --experimental-vm-modules ./scripts/tokenize-samples.mjs"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.1.0"
  }
}
