{
  "name": "katari-vscode",
  "displayName": "Katari",
  "description": "Syntax highlighting and language support for the Katari language.",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "publisher": "yukikurage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/katari-lang/katari.git",
    "directory": "typescript/vscode"
  },
  "bugs": "https://github.com/katari-lang/katari/issues",
  "homepage": "https://katari-lang.dev",
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "katari",
    "agent orchestration",
    "ai agents",
    "language server",
    "lsp"
  ],
  "contributes": {
    "commands": [
      {
        "command": "katari.check",
        "category": "Katari",
        "title": "Check project"
      },
      {
        "command": "katari.build",
        "category": "Katari",
        "title": "Build project"
      },
      {
        "command": "katari.apply",
        "category": "Katari",
        "title": "Apply (deploy) project"
      },
      {
        "command": "katari.mcpPull",
        "category": "Katari",
        "title": "Generate MCP tool bindings"
      },
      {
        "command": "katari.restartLanguageServer",
        "category": "Katari",
        "title": "Restart language server"
      }
    ],
    "languages": [
      {
        "id": "katari",
        "aliases": [
          "Katari",
          "katari"
        ],
        "extensions": [
          ".ktr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "katari",
        "scopeName": "source.katari",
        "path": "./syntaxes/katari.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Katari",
      "properties": {
        "katari.server.path": {
          "type": "string",
          "default": "katari-lsp",
          "description": "Path to the katari-lsp executable. Leave unset to use the server bundled with the extension (falling back to a katari-lsp on PATH); set an absolute path or a PATH name to override it with your own build."
        },
        "katari.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra command-line arguments passed to katari-lsp (useful for verbose logging flags during LSP development)."
        },
        "katari.cli.path": {
          "type": "string",
          "default": "katari",
          "description": "Path to the katari CLI executable used by the 'Katari: ...' commands (check, build, apply, mcp pull). Leave unset to use a katari on PATH (the extension bundles no CLI); set an absolute path or a PATH name to override it with your own build."
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/bundle.mjs",
    "typecheck": "tsc -p . --noEmit",
    "vscode:prepublish": "NODE_ENV=production node scripts/bundle.mjs",
    "server:copy": "node scripts/copy-server-binary.mjs",
    "package": "vsce package --no-dependencies --out katari-vscode.vsix",
    "package:local": "node scripts/copy-server-binary.mjs && node scripts/bundle.mjs && vsce package --no-dependencies --out katari-vscode.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@katari-lang/language": "workspace:*",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.4.0"
  }
}
