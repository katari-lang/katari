# Copy to `.env` (gitignored) and fill in KATARI_SECRET_KEY — the one entry with no default:
#
#   cp .env.example .env
#   echo "KATARI_SECRET_KEY=$(openssl rand -base64 32)" >> .env
#
# Two consumers read this one top-level file, both explicitly:
#   - the runtime dev script (`pnpm --filter @katari-lang/runtime dev`) via node's own
#     `--env-file-if-exists` flags — a package-local typescript/runtime/.env (if present) and real
#     environment variables both win over this file;
#   - `docker compose`, which substitutes these into compose.yaml (KATARI_SECRET_KEY, *_PORT).
# Production never reads .env files: the server takes real environment variables only.

# ── Runtime server ────────────────────────────────────────────────────────────
#PORT=3000
# Interface to bind. 0.0.0.0 (all interfaces) is required in a container; use 127.0.0.1 to
# restrict the unauthenticated v0.1 API to loopback.
#HOST=0.0.0.0
#LOG_LEVEL=info
#NODE_ENV=development
# Allowed CORS origin(s): * (default) or a comma-separated allowlist. The API is currently
# unauthenticated, so lock this down in any shared deployment.
#CORS_ORIGIN=*

# postgres://user:password@host:port/database — matches the compose.yaml postgres service.
#DATABASE_URL=postgres://katari:katari@localhost:5432/katari

# Encryption key for secret (private) values at rest (base64, 32 bytes). REQUIRED — the runtime
# refuses to boot without it, since a missing key would silently persist secrets in plaintext.
# Generate your own (see above) — do NOT ship a key from version control.
KATARI_SECRET_KEY=

# Blob bytes: leave unset for the in-memory dev store, or point at an S3-compatible bucket.
# Credentials come from the standard AWS chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY);
# BLOB_S3_ENDPOINT + BLOB_S3_FORCE_PATH_STYLE=true target a non-AWS endpoint such as MinIO.
#BLOB_S3_BUCKET=
#BLOB_S3_REGION=us-east-1
#BLOB_S3_ENDPOINT=
#BLOB_S3_FORCE_PATH_STYLE=false

# ── docker compose ────────────────────────────────────────────────────────────
# Host ports the compose services publish.
#POSTGRES_PORT=5432
#APP_PORT=3000
