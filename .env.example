# ============================================================
# Katari Development Environment
# Copy this file to .env and fill in the required values
# ============================================================

# --- Required for Discord server ---
DISCORD_TOKEN=your-discord-bot-token

# --- Required for AI server ---
GEMINI_API_KEY=your-gemini-api-key
AI_PROVIDER=gemini

# --- Required for Web Search server ---
TAVILY_API_KEY=your-tavily-api-key

# --- Required for Sandbox server (E2B) ---
E2B_API_KEY=your-e2b-api-key

# --- Optional port overrides ---
# KATARI_PORT=8000
# KATARI_DB_PORT=5432
# KATARI_DISCORD_PORT=8001
# KATARI_AI_PORT=8002
# KATARI_CRON_PORT=8003
# KATARI_WEBSEARCH_PORT=8004
# KATARI_SANDBOX_PORT=8005

# --- Local development (without Docker) ---
# DATABASE_URL=postgresql://katari:katari@localhost:5432/katari
