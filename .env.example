# Discord
DISCORD_TOKEN=your-discord-bot-token

# AI (Gemini)
GEMINI_API_KEY=your-gemini-api-key
AI_PROVIDER=gemini

# Web Search (Google Custom Search)
SEARCH_API_KEY=your-google-api-key
SEARCH_ENGINE_ID=your-search-engine-id

# Tool routes for AI server (maps tool names to external server endpoints)
TOOL_ROUTES={"ext.send_message":{"url":"http://discord:8001/katari","def":"send_message","description":"メッセージを送信する","params":[{"name":"channel_id","type":"string","description":"送信先チャンネルID"},{"name":"content","type":"string","description":"メッセージ本文"}]},"ext.reply_to":{"url":"http://discord:8001/katari","def":"reply_to","description":"メッセージに返信する","params":[{"name":"channel_id","type":"string","description":"チャンネルID"},{"name":"message_id","type":"string","description":"返信先メッセージID"},{"name":"content","type":"string","description":"返信本文"}]},"ext.fetch_messages":{"url":"http://discord:8001/katari","def":"fetch_messages","description":"チャンネルの最新メッセージを取得する","params":[{"name":"channel_id","type":"string","description":"チャンネルID"},{"name":"limit","type":"integer","description":"取得件数"}]},"ext.web_search":{"url":"http://websearch:8004/katari","def":"search","description":"Webを検索して結果を取得する","params":[{"name":"query","type":"string","description":"検索クエリ"}]},"ext.create_sandbox":{"url":"http://sandbox:8005/katari","def":"create","description":"Docker sandboxを作成する","params":[]},"ext.exec_in_sandbox":{"url":"http://sandbox:8005/katari","def":"exec","description":"sandboxでコマンドを実行する","params":[{"name":"sandbox_id","type":"string","description":"サンドボックスID"},{"name":"command","type":"string","description":"実行するコマンド"}]},"ext.write_file_in_sandbox":{"url":"http://sandbox:8005/katari","def":"write_file","description":"sandboxにファイルを書き込む","params":[{"name":"sandbox_id","type":"string","description":"サンドボックスID"},{"name":"path","type":"string","description":"ファイルパス"},{"name":"content","type":"string","description":"ファイル内容"}]},"ext.read_file_from_sandbox":{"url":"http://sandbox:8005/katari","def":"read_file","description":"sandboxからファイルを読み込む","params":[{"name":"sandbox_id","type":"string","description":"サンドボックスID"},{"name":"path","type":"string","description":"ファイルパス"}]},"ext.destroy_sandbox":{"url":"http://sandbox:8005/katari","def":"destroy","description":"sandboxを破棄する","params":[{"name":"sandbox_id","type":"string","description":"サンドボックスID"}]}}
