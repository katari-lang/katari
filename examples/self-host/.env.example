# Copy this file to `.env` and edit before `docker compose up -d`.

# Postgres password (required). Generate a strong value:
#   openssl rand -hex 32
POSTGRES_PASSWORD=changeme

# Port the runtime listens on (default 8000).
KATARI_PORT=8000

# Image owner (GHCR namespace). Defaults to "katari-lang".
# KATARI_IMAGE_OWNER=katari-lang

# Image version. Defaults to "latest"; pin to a specific tag for prod:
#   KATARI_VERSION=0.1.0
# KATARI_VERSION=latest

# Log verbosity: debug | info | warn | error.
# KATARI_LOG_LEVEL=info

# ─── Blob storage ──────────────────────────────────────────────────────────
# Blob bytes use S3-compatible storage (metadata stays in Postgres). This
# stack bundles a durable SeaweedFS store, pre-wired in docker-compose.yml —
# nothing to configure here. It persists in the `blobdata` volume.
#
# To use a cloud bucket instead (AWS S3 / Cloudflare R2 / Backblaze B2 / …):
# edit the runtime's KATARI_S3_* in docker-compose.yml to point at it and
# remove the `seaweedfs` service. (S3 is required — there is no local-disk
# fallback, so a misconfigured runtime fails fast at startup instead of
# silently losing data on restart.)
