// The language tour: data + match, for (a map with an optional accumulator), parallel evaluation,
// effects with inline handlers, and a sampling of the prelude (string / array / math). Every agent
// here is independently runnable — `katari run basics.main` exercises them all in one pass.

@"A circle, by radius."
data circle(radius: number)

@"An axis-aligned rectangle."
data rect(width: number, height: number)

// One shape. `match` scrutinises the constructor; field patterns bind with `=>`.
type shape = circle | rect

@"The area of a shape — constructor dispatch with `match`."
agent area(value: shape) -> number {
  match (value) {
    case circle(radius => r) -> 3.14159 * r * r
    case rect(width => w, height => h) -> w * h
  }
}

@"A capability: each call yields the next counter value. Provided by the handler in `main`."
request tick() -> integer

@"Three ticks, in order — the ambient `tick` capability does the counting."
agent count_three() -> array[integer] with tick {
  [tick(), tick(), tick()]
}

@"Sum with a `for` accumulator: `next with { ... }` threads state, `then` picks the result."
agent sum(values: array[integer]) -> integer {
  for (let value in values, var total: integer = 0) {
    next with { total = total + value }
  } then (_elements) { total }
}

@"The first squares, computed as a parallel map — each element is its own thread."
agent squares(count: integer) -> array[integer] {
  parallel for (let n in array.range(start = 1, end = count + 1)) {
    next n * n
  }
}

@"Scale a value by a factor — the two-parameter agent `main` partially applies below."
agent scale(factor: number, value: number) -> number {
  factor * value
}

@"Partial application: `scale(factor = 2.0, value = _)` fixes the factor NOW and yields a residual
`agent (value: number) -> number`; each later call supplies only the holes."
agent doubles(values: array[number]) -> array[number] {
  let double = scale(factor = 2.0, value = _)
  for (let value in values) { next double(value = value) }
}

@"Decorate `body`, with a fixed `prefix` and an optional `suffix` that defaults to `\"!\"`."
agent decorate(prefix: string, body: string, suffix: string ?= "!") -> string {
  f"${prefix}${body}${suffix}"
}

@"Partial application meets defaults: this bakes in `prefix`, holes `body`, and OMITS the optional
`suffix` entirely (not holed, not supplied). So each residual call carries only `body`, and the
callee's runtime default fills `suffix` THROUGH the residual — a defaulted parameter stays defaulted."
agent decorated() -> string {
  let mark = decorate(prefix = ">> ", body = _)
  mark(body = "hello")
}

@"Run the whole tour and render one summary line."
agent main() -> string {
  // A stateful inline handler provides `tick` to the rest of the block.
  use handler (var counter = 0) {
    request tick() { next counter with { counter = counter + 1 } }
  }
  let shapes = [circle(radius = 1.0), rect(width = 2.0, height = 3.0)]
  let areas = for (let s in shapes) { next area(value = s) }
  let total = sum(values = squares(count = 4))
  let parts = [
    f"areas=${json.to_text(value = areas)}",
    f"ticks=${json.to_text(value = count_three())}",
    f"sum(squares(4))=${string.to_string(value = total)}",
    f"doubles=${json.to_text(value = doubles(values = [1.5, 21.0]))}",
    f"decorated=${decorated()}",
    f"shout=${string.to_upper(value = "hello, katari")}",
  ]
  string.join(parts = parts, separator = " | ")
}
