// The FFI in one module: an external agent is declared here and implemented in `ffi.ts` (the same
// module path, so `greet` registers under the key `playground.ffi.greet`). `katari apply` bundles the sidecar;
// the runtime spawns it per snapshot and dispatches calls to it. Four boundary shapes:
//
//   greet         — plain values across the boundary.
//   make_greeting — a `file` produced by the sidecar (bytes ride the blob side channel).
//   byte_length   — a `file` consumed by the sidecar (downloaded back).
//   compute       — inner delegation: the handler calls the katari agent `double` back
//                   through the runtime (`context.call`), then finishes.
//   parse_port    — a typed error: the handler raises `katari.throw` with a `parse_error`
//                   data value, caught here as an ordinary `throw[parse_error]`.

@"Plain values in, plain value out."
external agent greet(name: string) -> string

@"The sidecar builds a text file; the bytes travel on the blob side channel."
external agent make_greeting(name: string) -> file

@"The sidecar downloads the file's bytes and measures them."
external agent byte_length(content: file) -> integer

@"The sidecar calls `double` back through the runtime, then adds one."
external agent compute(x: integer) -> integer

@"The typed error `parse_port` raises for non-numeric text."
data parse_error(message: string)

@"Parse a TCP port; the sidecar raises `throw[parse_error]` on non-numeric text."
external agent parse_port(text: string) -> integer with prelude.throw[parse_error]

@"The katari-side callee of `compute`'s inner delegation."
agent double(x: integer) -> integer {
  x * 2
}

@"Entry: exercise every boundary shape and render one summary line."
agent main(name: string) -> string {
  let greeting = greet(name = name)
  let size = byte_length(content = make_greeting(name = name))
  let computed = compute(x = 20)
  let port = {
    use handler {
      request prelude.throw(error: parse_error) -> never { break 8080 }
    }
    parse_port(text = "not-a-port")
  }
  let parts = [
    greeting,
    f"bytes=${string.to_string(value = size)}",
    f"compute(20)=${string.to_string(value = computed)}",
    f"fallback_port=${string.to_string(value = port)}",
  ]
  string.join(parts = parts, separator = " | ")
}
