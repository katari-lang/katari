// The built-in MCP client, end to end: `use mcp.provide(url = ...)` lists any MCP server's tools as a
// toolbox of AGENTS — one per server tool, minted by the runtime with the server-declared name /
// description / input schema — and hands them to the rest of the block as a scope. The reflection loop
// (`reflection.get_metadata` reads a tool's signature, `reflection.call_agent` dispatches it with
// runtime-built args, validated against the server's schema before the server is contacted — a tool IS
// an agent) runs INSIDE that `provide` scope: a tool call raises `mcp.scope`, discharged when `provide`
// returns, so a tool cannot escape the block. There is no connection to manage: each tool carries its
// server descriptor and the runtime (re)connects lazily, closing on scope exit.
//
// Deterministic given a server: the e2e suite starts a local MCP server exposing one `add` tool and
// passes its URL as the argument. The dynamic path uses the built-in `mcp.scope` marker, so the toolbox
// is `mcp.toolbox[mcp.scope]`; the url is a plain routing value.

@"List the MCP server at @url@, report its tool names (from each minted agent's metadata), and call
its `add` tool through the same dynamic dispatch an AI loop uses — all inside the `provide` scope the
tools are gated by."
agent main(url: string) -> string {
  use handler {
    request prelude.throw(error: mcp.server_error | mcp.auth_error | reflection.call_error) -> never {
      break f"mcp failed: ${json.to_text(value = error)}"
    }
  }
  let tools : mcp.toolbox[mcp.scope] = use mcp.provide[mcp.scope](url = url, auth = mcp.headers(values = record.empty()))
  let names = for (let tool in record.values(target = tools)) {
    next reflection.get_metadata(value = tool).name
  }
  let added = match (record.get(target = tools, key = "add")) {
    case null -> "(no add tool)"
    case tool -> json.to_text(value = reflection.call_agent(target = tool, args = { x = 19, y = 23 }))
  }
  f"tools=${string.join(parts = names, separator = ",")}; add=${added}"
}
