@"An AI provider connection: credentials + model. Built once, shared via get_ai_client."
data ai_client(provider: string, model: string, api_key: secret)

@"The shared AI client capability (provided once at the root)."
request get_ai_client() -> ai_client

@"The live Discord gateway connection (the JS client lives in the sidecar)."
request get_discord_client() -> string

@"The current conversation session handle (its message history lives in the sidecar)."
request get_session() -> string

@"Raised once per incoming message; the caller installs a handler to react however it likes."
request on_message(text: string, channel_id: string) -> null

@"Open a fresh conversation session; the history is kept in the sidecar."
external create_session() -> string from "FFI:discord_bot.create_session"

@"Run one turn: appends the prompt to the session's history, infers, returns the reply."
external ai_infer(client: ai_client, session: string, prompt: string) -> string from "FFI:discord_bot.ai_infer"

@"Connect to Discord and log in; returns an opaque client handle."
external create_discord_client(token: secret) -> string from "FFI:discord_bot.create_discord_client"

@"Low-level: post to a channel on a given client. Prefer the send_message agent."
external discord_send(client: string, channel_id: string, text: string) -> null from "FFI:discord_bot.discord_send"

@"Low-level: listen on a channel and deliver each message to a callback. Prefer the watch_messages agent."
external discord_watch(client: string, channel_id: string, on_message: agent (text: string, channel_id: string) -> null with on_message) -> never from "FFI:discord_bot.discord_watch"

@"Infer using the ambient AI client + session."
agent infer(prompt: string) -> string with get_ai_client, get_session {
  ai_infer(client = get_ai_client(), session = get_session(), prompt = prompt)
}

@"Post a message to a channel using the ambient Discord client."
agent send_message(channel_id: string, text: string) -> null with get_discord_client {
  discord_send(client = get_discord_client(), channel_id = channel_id, text = text)
}

@"Bridge: turn each delivered message into an on_message request for the caller to handle."
agent deliver(text: string, channel_id: string) -> null with on_message {
  on_message(text = text, channel_id = channel_id)
}

@"Serve a channel forever, raising on_message for each message. Just provide the channel + a handler."
agent watch_messages(channel_id: string) -> never with on_message, get_discord_client {
  discord_watch(client = get_discord_client(), channel_id = channel_id, on_message = deliver)
}

@"The e2b API key capability (provided once at the root)."
request get_e2b_key() -> secret

@"Run Python in an e2b sandbox; returns the stdout / value / error text."
external e2b_exec(code: string, api_key: secret) -> string from "FFI:discord_bot.e2b_exec"

@"Tool: execute Python code and return its output."
agent run_python(code: string) -> string with get_e2b_key {
  e2b_exec(code = code, api_key = get_e2b_key())
}

@"Infer with a tool the model may call; the ext runs the tool-call feedback loop, dispatching the tool via delegate. (v0: one tool — v1 makes tool/tool_* arrays.)"
external infer_with_tools(
  client: ai_client,
  session: string,
  prompt: string,
  tool_name: string,
  tool_description: string,
  tool_input: string,
  tool: agent (code: string) -> string with get_e2b_key
) -> string from "FFI:discord_bot.infer_with_tools"

@"Ask the model, letting it call run_python. The tool's schema comes from get_metadata, so v1 = map this over a tools array."
agent ask(prompt: string) -> string with get_ai_client, get_session, get_e2b_key {
  match (get_metadata(value = run_python)) {
    case agent_metadata(name = tool_name, id = _, description = tool_description, input = tool_input, output = _) => {
      infer_with_tools(
        client = get_ai_client(),
        session = get_session(),
        prompt = prompt,
        tool_name = tool_name,
        tool_description = tool_description,
        tool_input = tool_input,
        tool = run_python,
      )
    }
  }
}

@"Standalone entry to test the tool loop from the CLI (no Discord): katari run discord_bot.solve --args '{\"task\": \"...\"}'."
agent solve(task: string) -> string {
  handle {
    request env_not_found(env_key: string) {
      break f"missing env: ${env_key}"
    }
  }
  handle (var ai = ai_client(provider = "gemini", model = "gemini-3.1-flash-lite", api_key = get_secret_env(key = "GEMINI_API_KEY"))) {
    request get_ai_client() {
      next ai
    }
  }
  handle (var e2b_key = get_secret_env(key = "E2B_API_KEY")) {
    request get_e2b_key() {
      next e2b_key
    }
  }
  handle (var s = create_session()) {
    request get_session() {
      next s
    }
  }
  ask(prompt = task)
}

@"Entry: set up the AI client + Discord connection + a session, then serve one channel forever."
agent main(channel_id: string) -> string {
  handle {
    request env_not_found(env_key: string) {
      break f"missing env: ${env_key}"
    }
  }
  handle (var ai = ai_client(provider = "gemini", model = "gemini-3.1-flash-lite", api_key = get_secret_env(key = "GEMINI_API_KEY"))) {
    request get_ai_client() {
      next ai
    }
  }
  handle (var discord = create_discord_client(token = get_secret_env(key = "DISCORD_TOKEN"))) {
    request get_discord_client() {
      next discord
    }
  }
  handle (var s = create_session()) {
    request get_session() {
      next s
    }
  }
  handle {
    request on_message(text: string, channel_id: string) {
      let reply = infer(prompt = text)
      send_message(channel_id = channel_id, text = reply)
      next null
    }
  }
  watch_messages(channel_id = channel_id)
}
