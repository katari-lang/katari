// The Discord bot APP: it wires the reusable `ai` and `discord` library modules
// together, supplies its own tool (run Python in an e2b sandbox), and provides
// the capabilities (`ai.get_ai_client`, `discord.get_discord_client`,
// `get_e2b_key`) at the root. The two `import`ed modules could be split into
// their own packages without touching this file's logic.

import discord_bot.ai
import discord_bot.discord

@"The e2b API key capability (provided once at the root)."
request get_e2b_key() -> secret

@"Run Python in an e2b sandbox; returns the stdout / value / error text."
external e2b_exec(code: string, api_key: secret) -> string from "FFI:discord_bot.e2b_exec"

@"Tool: execute Python code and return its output."
agent run_python(code: string) -> string with get_e2b_key {
  e2b_exec(code = code, api_key = get_e2b_key())
}

@"Run the tool-using model loop over a history (its last turn is the user's task). The tools all share the @get_e2b_key@ effect, which `ai.infer_with_tools[get_e2b_key]` tracks through to here."
agent ask(history: array[ai.message], tools: array[agent (...never) -> unknown with get_e2b_key]) -> string with ai.get_ai_client | get_e2b_key | error_invalid_argument {
  ai.infer_with_tools[get_e2b_key](history = history, tools = tools, max_steps = 8)
}

@"Standalone entry to test the tool loop from the CLI (no Discord): katari run discord_bot.solve --args '{\"task\": \"...\"}'."
agent solve(task: string) -> string {
  handle {
    request env_not_found(env_key: string) {
      break f"missing env: ${env_key}"
    }
  }
  handle (var client = ai.ai_client(provider = "gemini", model = "gemini-3.1-flash-lite", api_key = env.get_secret(key = "GEMINI_API_KEY"))) {
    request ai.get_ai_client() {
      next client
    }
  }
  handle (var e2b_key = env.get_secret(key = "E2B_API_KEY")) {
    request get_e2b_key() {
      next e2b_key
    }
  }
  ask(
    history = array.append(array = array.empty(), value = ai.turn(role = "user", text = task)),
    tools = [run_python],
  )
}

@"Entry: set up the AI client + Discord connection, then serve one channel forever, keeping the conversation history as a Katari value."
agent main(channel_id: string) -> string {
  handle {
    request env_not_found(env_key: string) {
      break f"missing env: ${env_key}"
    }
  }
  handle (var client = ai.ai_client(provider = "gemini", model = "gemini-3.1-flash-lite", api_key = env.get_secret(key = "GEMINI_API_KEY"))) {
    request ai.get_ai_client() {
      next client
    }
  }
  handle (var discord_client = discord.create_discord_client(token = env.get_secret(key = "DISCORD_TOKEN"))) {
    request discord.get_discord_client() {
      next discord_client
    }
  }
  handle (var history: array[ai.message] = array.empty()) {
    request discord.on_message(text: string, channel_id: string) {
      let asked = array.append(array = history, value = ai.turn(role = "user", text = text))
      let reply = ai.ai_infer(client = ai.get_ai_client(), history = asked)
      discord.send_message(channel_id = channel_id, text = reply)
      next null with { history = array.append(array = asked, value = ai.turn(role = "model", text = reply)) }
    }
  }
  discord.watch_messages(channel_id = channel_id)
}
