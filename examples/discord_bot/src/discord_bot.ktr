// The Discord bot APP. It wires the reusable library modules — the provider-
// agnostic `ai` orchestration (+ its `gemini` / `openai` providers), `discord`,
// and the `e2b` tool — and provides the capabilities at the root. Swapping the
// model or provider is a one-line change to the client built below; none of the
// library modules know anything Discord- or e2b-specific.

import discord_bot.ai
import discord_bot.ai.types
import discord_bot.ai.gemini
import discord_bot.discord
import discord_bot.e2b

@"Run the tool-using model loop over a history (its last turn is the user's task). The tools all share the @e2b.get_e2b_key@ effect, which `ai.infer_with_tools[e2b.get_e2b_key]` tracks through to here."
agent ask(history: array[types.message], tools: array[agent (...never) -> unknown with e2b.get_e2b_key]) -> string with ai.get_ai_client | e2b.get_e2b_key | json_parse_error | error_invalid_argument {
  ai.infer_with_tools[e2b.get_e2b_key](history = history, tools = tools, max_steps = 8)
}

@"The provider connection this bot uses. Swap gemini -> openai (and the model id) to change provider; nothing else changes."
agent build_client() -> ai.ai_client {
  gemini.gemini(
    model = "gemini-3.5-flash",
    api_key = env.get_secret(key = "GEMINI_API_KEY"),
    config = types.infer_config(system = "You are a helpful assistant in a Discord channel."),
  )
}

@"Standalone entry to test the tool loop from the CLI (no Discord): katari run discord_bot.solve --args '{\"task\": \"...\"}'."
agent solve(task: string) -> string {
  use handler {
    request env_not_found(env_key: string) {
      break f"missing env: ${env_key}"
    }
  }
  use handler (var client = build_client()) {
    request ai.get_ai_client() {
      next client
    }
  }
  use handler (var e2b_key = env.get_secret(key = "E2B_API_KEY")) {
    request e2b.get_e2b_key() {
      next e2b_key
    }
  }
  ask(
    history = array.append(array = array.empty(), value = types.turn(role = "user", text = task)),
    tools = [e2b.run_python],
  )
}

@"Entry: set up the AI client + Discord connection, then serve one channel forever, keeping the conversation history as a Katari value."
agent main(channel_id: string) -> string {
  use handler {
    request env_not_found(env_key: string) {
      break f"missing env: ${env_key}"
    }
  }
  use handler (var client = build_client()) {
    request ai.get_ai_client() {
      next client
    }
  }
  use handler (var discord_client = discord.create_discord_client(token = env.get_secret(key = "DISCORD_TOKEN"))) {
    request discord.get_discord_client() {
      next discord_client
    }
  }
  use handler (var history: array[types.message] = array.empty()) {
    request discord.on_message(text: string, channel_id: string) {
      let asked = array.append(array = history, value = types.turn(role = "user", text = text))
      let answer = ai.reply(history = asked)
      discord.send_message(channel_id = channel_id, text = answer)
      next null with { history = array.append(array = asked, value = types.turn(role = "model", text = answer)) }
    }
  }
  discord.watch_messages(channel_id = channel_id)
}
