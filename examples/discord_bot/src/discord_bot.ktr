// The Discord bot APP. It wires the reusable library modules — the provider-agnostic `ai`
// orchestration (+ its `gemini` / `openai` providers), `discord`, and the `e2b` tool — and
// provides the capabilities at the root with inline handlers. Swapping the model or provider is a
// one-line change inside `make_client`; none of the library modules know anything Discord- or
// e2b-specific.

import discord_bot.ai
import discord_bot.ai.types
import discord_bot.ai.gemini
import discord_bot.api
import discord_bot.discord
import discord_bot.e2b

@"Run the tool-using model loop over a history (its last turn is the user's task). Generic over
the tools' shared effect @E@ (for `[e2b.run_python]` that is `e2b.get_e2b_key` + the FFI's io),
which `ai.infer_with_tools[E]` tracks through to the caller's handlers."
agent ask[effect E](history: array[types.message], tools: array[agent never -> unknown with E]) -> string {
  ai.infer_with_tools[E](history = history, tools = tools, max_steps = 8)
}

@"Build the provider connection ONCE (reading its key — a missing key panics here, caught by the
root's `panic` clause). Swap gemini -> openai (and the model id) to change provider; nothing else changes."
agent make_client() -> gemini.gemini {
  gemini.gemini(
    model = "gemini-2.5-flash",
    api_key = env.get_secret(key = "GEMINI_API_KEY"),
    config = types.infer_config(system = "You are a helpful assistant in a Discord channel."),
  )
}

@"Standalone entry to test the tool loop from the CLI (no Discord):
katari run discord_bot.solve --arg '{\"task\": \"...\"}'."
agent solve(task: string) -> string {
  // A missing env entry / interrupted sidecar is a panic; a provider or dispatch failure is a
  // typed throw. Both become readable strings here instead of failing the run.
  use handler { request panic(msg: string) { break f"failed: ${msg}" } }
  use handler {
    request prelude.throw(error: ai.loop_error) -> never {
      break f"provider error: ${json.to_text(value = error)}"
    }
  }
  use handler (var e2b_key = env.get_secret(key = "E2B_API_KEY")) {
    request e2b.get_e2b_key() { next e2b_key }
  }
  use handler (var client = make_client()) {
    request ai.get_ai_client() { next client }
  }
  ask(history = [types.turn(role = "user", text = task)], tools = [e2b.run_python])
}

@"Entry: set up the AI client + Discord connection, then serve one channel forever, keeping the
conversation history as a Katari value."
agent main(channel_id: string) -> string {
  use handler { request panic(msg: string) { break f"failed: ${msg}" } }
  use handler {
    request prelude.throw(error: ai.loop_error) -> never {
      break f"provider error: ${json.to_text(value = error)}"
    }
  }
  use handler (var client = make_client()) {
    request ai.get_ai_client() { next client }
  }
  use handler (var discord_client = discord.create_discord_client(token = env.get_secret(key = "DISCORD_TOKEN"))) {
    request discord.get_discord_client() { next discord_client }
  }
  use handler (var history: array[types.message] = []) {
    request discord.on_message(text: string, channel_id: string) {
      let asked = array.append(target = history, value = types.turn(role = "user", text = text))
      let answer = ai.reply(history = asked)
      discord.send_message(channel_id = channel_id, text = answer)
      next null with { history = array.append(target = asked, value = types.turn(role = "model", text = answer)) }
    }
  }
  discord.watch_messages(channel_id = channel_id)
}
