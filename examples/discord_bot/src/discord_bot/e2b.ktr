// A self-contained tool: run Python in an e2b sandbox. Its own capability (`get_e2b_key`) + the
// low-level external + the `run_python` agent an app hands to the model as a tool.

@"The e2b API key capability (provided once at the root)."
request get_e2b_key() -> string of private

@"Run Python in an e2b sandbox; returns the stdout / value / error text."
external agent e2b_exec(code: string, api_key: string of private) -> string

@"Tool: execute Python code and return its output."
agent run_python(code: string) -> string {
  e2b_exec(code = code, api_key = get_e2b_key())
}
