// Small JSON read helpers ‚Äî plain Katari over the `json` data union. `record.get` / `array.get`
// are typed `V | null` (null on absent key / out-of-range index), so `or_null` folds that null
// back into the `json` world as `json_null()`; the readers below are then thin match wrappers.

@"Fold a nullable json read (`record.get` / `array.get`, typed `json | null`) back into `json`:
a missing value becomes `json_null()`. Matching the `null` arm narrows the residual to `json`, so the
fallthrough binds `present` at `json` and returns it unchanged."
agent or_null(value: json.json | null) -> json.json {
  match (value) {
    case null -> json.json_null()
    case present -> present
  }
}

@"The child at object key @key@ (json_null if @node@ is not an object or has no such key)."
agent field(node: json.json, key: string) -> json.json {
  match (node) {
    case json.json_object(entries => entries) -> or_null(value = record.get(target = entries, key = key))
    case _ -> json.json_null()
  }
}

@"The element at array index @index@ (json_null if @node@ is not an array or @index@ is out of range)."
agent elem(node: json.json, index: integer) -> json.json {
  match (node) {
    case json.json_array(items => items) -> or_null(value = array.get(target = items, index = index))
    case _ -> json.json_null()
  }
}

@"The string @node@ holds (empty string if it is not a json_string)."
agent text(node: json.json) -> string {
  match (node) {
    case json.json_string(value => string_value) -> string_value
    case _ -> ""
  }
}
