// The AI orchestration layer: the provider-agnostic public surface. It unions the providers into
// one `ai_client`, dispatches a model step to the right one, and runs the tool-using loop
// generically over the tools' shared effect. Apps (and the providers) speak only the agnostic
// vocabulary in discord_bot.ai.types.

import discord_bot.ai.types
import discord_bot.ai.jsonx
import discord_bot.ai.gemini
import discord_bot.ai.openai
import discord_bot.api

// One configured provider connection. Add a provider by adding a data type in its own module and a
// branch here + in infer_step — nothing else changes.
type ai_client = gemini.gemini | openai.openai

// The error surface of one model step: malformed provider JSON, a non-2xx API status, or a
// transport failure. (Type synonyms take no docs.)
type step_error = json.parse_error | api.api_error | http.fetch_error

// Everything the tool loop can raise: a step error or a bad dynamic dispatch.
type loop_error = step_error | ai.call_error

@"The shared AI client capability (provided once at the root)."
request get_ai_client() -> ai_client

@"One model step, dispatched to the configured provider. Provider-agnostic in / out (history + tool schemas -> a step decision)."
agent infer_step(client: ai_client, history: array[types.message], tool_metas: array[ai.agent_metadata]) -> types.step {
  match (client) {
    case gemini.gemini(model => model, api_key => api_key, config => config) -> {
      gemini.gemini_infer_step(client = gemini.gemini(model = model, api_key = api_key, config = config), history = history, tool_metas = tool_metas)
    }
    case openai.openai(model => model, api_key => api_key, config => config) -> {
      openai.openai_infer_step(client = openai.openai(model = model, api_key = api_key, config = config), history = history, tool_metas = tool_metas)
    }
  }
}

@"Infer a single reply with no tools (the common chat case)."
agent reply(history: array[types.message]) -> string {
  match (infer_step(client = get_ai_client(), history = history, tool_metas = [])) {
    case types.step_final(text => text) -> text
    case types.step_call(calls => _) -> "(unexpected tool call without tools)"
  }
}

@"Run the tool-using model loop IN KATARI, generic over the tools' shared effect @E@: derive each
tool's schema with `ai.get_metadata`, then up to @max_steps@ times ask the configured provider for
a step; on a batch of tool calls, dispatch them all CONCURRENTLY with `parallel for` (each resolves
its tool by index and invokes it by value via `ai.call_agent`, validating the model's args against
the tool's schema), then feed every result back as a new turn; on a final answer, return it."
agent infer_with_tools[effect E](
  history: array[types.message],
  tools: array[agent never -> unknown with E],
  max_steps: integer,
) -> string {
  let tool_metas = for (let tool in tools) { next ai.get_metadata(value = tool) }
  for (let _step in array.range(start = 0, end = max_steps), var conversation: array[types.message] = history) {
    match (infer_step(client = get_ai_client(), history = conversation, tool_metas = tool_metas)) {
      case types.step_final(text => reply_text) -> { break reply_text }
      case types.step_call(calls => calls) -> {
        // Dispatch every requested tool in parallel; results come back in request order, each
        // tagged with its tool name + call id so it round-trips as a function response.
        let results = parallel for (let call in calls) {
          next types.tool_result(
            name = call.name,
            call_id = call.opaque,
            text = dispatch_one[E](tools = tools, call = call),
          )
        }
        // Record BOTH the model's call turn and the results turn so the next step replays the
        // full call / response exchange.
        let with_calls = array.append(target = conversation, value = types.call_turn(calls = calls))
        next with { conversation = array.append(target = with_calls, value = types.result_turn(results = results)) }
      }
    }
  } then (_steps) { "(no final answer within the step budget)" }
}

@"Find the tool whose metadata name is the model's pick and invoke it by value via `ai.call_agent`
(the delegation boundary validates the model-built args against the tool's schema). A hallucinated
name matches nothing and is fed back as an error result so the model can correct on the next step."
agent dispatch_one[effect E](tools: array[agent never -> unknown with E], call: types.tool_call) -> string {
  for (let tool in tools) {
    let meta = ai.get_metadata(value = tool)
    if (meta.name == call.name) {
      return json.to_text(value = ai.call_agent(target = tool, args = jsonx.to_value(node = call.args)))
    } else {
      null
    }
  }
  f"(error: unknown tool \"${call.name}\")"
}
