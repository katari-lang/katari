// The ONLY network helper the AI providers need: a JSON POST with one configurable auth header,
// as a thin wrapper over the built-in `http.fetch` (which runs on the runtime's http reactor — no
// sidecar involved). Each provider builds its request body as JSON *in Katari* and parses the
// response as JSON *in Katari*. Fully provider-agnostic — swapping or adding a provider never
// touches this module.

@"Raised when the API responds with a non-2xx status."
data api_error(status: integer, body: string)

@"POST @body@ to @url@ as application/json with one auth header @auth_header_name: <auth_prefix><api_key>@
(e.g. \"Authorization\" / \"Bearer \" for OpenAI, \"x-goog-api-key\" / \"\" for Gemini). Returns the
response body text; a non-2xx status raises `api_error`, a transport failure `http.fetch_error`."
agent post_json(
  url: string,
  body: string,
  auth_header_name: string,
  auth_prefix: string,
  api_key: string of private,
) -> string {
  let headers = record.set(
    target = record.set(target = record.empty(), key = "Content-Type", value = "application/json"),
    key = auth_header_name,
    value = auth_prefix ++ api_key,
  )
  let response = http.fetch(url = url, method = "POST", headers = headers, body = body)
  if (response.status >= 200 && response.status < 300) {
    response.body
  } else {
    prelude.throw(error = api_error(status = response.status, body = response.body))
  }
}
