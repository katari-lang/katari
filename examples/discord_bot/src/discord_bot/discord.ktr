// The Discord library: a gateway-client capability plus the watch / send agents. Independent of
// the AI layer — an app wires the two together by handling `on_message` with whatever logic it
// likes. The externals are implemented in `discord.ts` (the same module path, so they register
// under `discord_bot.discord.*`).

@"The live Discord gateway connection (the JS client lives in the sidecar; the handle is opaque)."
request get_discord_client() -> string

@"Raised once per incoming message; the caller installs a handler to react however it likes."
request on_message(text: string, channel_id: string) -> null

@"Connect to Discord and log in; returns an opaque client handle."
external agent create_discord_client(token: string of private) -> string

@"Low-level: post to a channel on a given client. Prefer the send_message agent."
external agent discord_send(client: string, channel_id: string, text: string) -> null

@"Low-level: listen on a channel and deliver each message to a callback. Prefer the watch_messages agent."
external agent discord_watch(client: string, channel_id: string, deliver_to: agent (text: string, channel_id: string) -> null with on_message) -> never with on_message

@"Post a message to a channel using the ambient Discord client."
agent send_message(channel_id: string, text: string) -> null {
  discord_send(client = get_discord_client(), channel_id = channel_id, text = text)
}

@"Bridge: turn each delivered message into an on_message request for the caller to handle."
agent deliver(text: string, channel_id: string) -> null with on_message {
  on_message(text = text, channel_id = channel_id)
}

@"Serve a channel forever, raising on_message for each message. Just provide the channel + a handler."
agent watch_messages(channel_id: string) -> never {
  discord_watch(client = get_discord_client(), channel_id = channel_id, deliver_to = deliver)
}
