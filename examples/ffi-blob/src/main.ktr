// FFI blob example. Two external (FFI) handlers move a blob's bytes over the runtime's side channel:
//   - `makeGreeting` PRODUCES a file — it generates bytes and uploads them, returning a `file` handle.
//   - `byteLength` CONSUMES a file — it downloads the received file's bytes and returns their length.
// `main` produces a greeting file and returns its byte length. The file itself is never returned, so it is
// reclaimed (its bytes freed from the blob store) when `main`'s instance tears down.

external agent makeGreeting(name: string) -> file
external agent byteLength(content: file) -> integer

agent main(name: string) -> integer {
  let greeting = makeGreeting(name = name)
  byteLength(content = greeting)
}
