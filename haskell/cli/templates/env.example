# Copy to `.env` (docker compose reads it) and fill in.

# At-rest encryption key for secret values (base64, 32 bytes) — generate one:
#   openssl rand -base64 32
# The runtime refuses to boot without a key; compose.yaml falls back to a dev-only default.
KATARI_SECRET_KEY=

# Where the CLI reaches the runtime (also set as [runtime].url in katari.toml).
KATARI_API_URL=http://localhost:3000
