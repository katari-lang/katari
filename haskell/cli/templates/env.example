# Copy to `.env` (docker compose reads it), then set the one required value:
#
#   cp .env.example .env
#   echo "KATARI_SECRET_KEY=$(openssl rand -base64 32)" >> .env

# At-rest encryption key for secret values (base64, 32 bytes). The runtime refuses to boot without it.
KATARI_SECRET_KEY=

# Where the CLI reaches the runtime. Also set as [runtime].url in katari.toml; override here to point
# the CLI at a remote deployment without editing the project file.
KATARI_API_URL=http://localhost:3000
