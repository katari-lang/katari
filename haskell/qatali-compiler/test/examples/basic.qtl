module Basic

// --- リテラル ---

let x = 42
let y = 3.14
let s = "hello"
let b = true
let n = null

// --- 算術・比較 ---

let sum = 1 + 2
let diff = 10 - 3
let prod = 4 * 5
let quot = 10 / 2
let eq = 1 == 1
let lt = 2 < 3

// --- 条件式 (if の body は必ず block) ---

let abs_val = fn (x: number) -> number {
  if x < 0 { 0 - x } else { x }
}

// --- let with type annotation ---

let pi: number = 3.14159

// --- 無名関数 (fn の body は必ず block) ---

let add = fn (x: integer, y: integer) -> number { x + y }

// --- 配列 ---

let nums = [1, 2, 3]

// --- テンプレートリテラル ---

let greeting = `hello`

// --- match 式 ---

let describe = fn (v: boolean) -> string {
  match v {
    case (true)  => "yes"
    case (false) => "no"
  }
}

// --- fn 宣言形式 ---

fn double(x: integer) -> number { x * 2 }

// --- ブロック本体 ---

fn add_and_double(x: integer, y: integer) -> number {
  let z = x + y
  return z * 2
}

// --- データ型 (タプル形式) ---

data Box<out T>(value: T)

fn unbox(b: Box<integer>) -> integer {
  match b {
    case (Box(v)) => v
  }
}

// --- データ型 (レコード形式) ---

data User<out ID> {
  id: ID,
  name: string
}

fn getUserName(u: User<integer>) -> string {
  match u {
    case User {name = n} => n
  }
}

// --- 型エイリアス ---

type IntOrStr = integer | string

let aliased: IntOrStr = 42

// --- ジェネリクス ---

fn identity<T>(x: T) -> T { x }

fn bounded<T sub number>(x: T) -> number { x }

// --- エフェクト宣言 ---

effect Log<out T>(message: T) -> null
effect Ask<in T, out R>(prompt: T) -> R

// --- 高階関数 ---

fn apply(f: (x: integer) => string, x: integer) -> string { f(x) }

fn compose(
  f: (x: integer) => string,
  g: (x: string) => boolean,
  x: integer
) -> boolean { g(f(x)) }

// --- if-else union ---

fn branch(b: boolean) -> integer | string {
  if b { 42 } else { "hello" }
}

// --- Result 型パターンマッチ ---

data Ok<out T>(value: T)
data Err<out E>(error: E)

fn dispatch(
  r: Ok<integer> | Err<string>,
  fallback: (x: string) => integer
) -> integer {
  match r {
    case (Ok(v)) => v
    case (Err(e)) => fallback(e)
  }
}
