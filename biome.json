{
  "$schema": "https://biomejs.dev/schemas/2.0.6/schema.json",
  "files": {
    "includes": [
      "typescript/packages/*/src/**/*.ts",
      "typescript/packages/*/src/**/*.tsx",
      "e2e/**/*.ts",
      "scripts/**/*.mjs"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "off"
      },
      "complexity": {
        "useLiteralKeys": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off",
        "useImportType": "warn"
      },
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  }
}
