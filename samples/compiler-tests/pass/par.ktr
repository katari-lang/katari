// par.ktr -- par blocks for parallel execution

// basic par with two branches
agent basic_par() -> array[integer] {
  par [
    { 1 + 2 },
    { 3 + 4 }
  ]
}

// par with three branches
agent triple_par() -> array[string] {
  par [
    { "hello" },
    { "world" },
    { "!" }
  ]
}

// par with complex expressions
agent complex_par() -> array[string] {
  let prefix = "result"
  par [
    {
      let x = 10
      f"${prefix}: ${x}"
    },
    {
      let y = 20
      f"${prefix}: ${y}"
    }
  ]
}

// par with if expressions in branches
agent par_with_if() -> array[integer] {
  let flag = true
  par [
    {
      if flag { 1 } else { 0 }
    },
    {
      if !flag { 1 } else { 0 }
    }
  ]
}

// empty par
agent empty_par() -> array[null] {
  par []
}
