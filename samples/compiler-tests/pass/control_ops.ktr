// control_ops.ktr -- exhaustive control operator tests

request get_value() -> integer
request set_value(v: integer) -> null

// ── return ───────────────────────────────────────────────────────

// return from agent body directly
agent return_direct() -> integer {
  return 42
}

// return from if branch
agent return_in_if(x: integer) -> string {
  if x > 0 {
    return "positive"
  }
  "non-positive"
}

// return from nested if
agent return_in_nested_if(x: integer) -> string {
  if x > 0 {
    if x > 100 {
      return "big"
    }
    return "small positive"
  }
  "non-positive"
}

// return from match arm
agent return_in_match(x: integer | string) -> string {
  match x {
    case integer(n) => {
      return f"int: ${n}"
    }
    case string(s) => {
      return s
    }
  }
  "unreachable"
}

// return inside for loop (exits the agent, not just the loop)
agent return_in_for() -> integer {
  for (let x of [1, 2, 3]) {
    if x == 2 {
      return 999
    }
  }
  0
}

// return inside handle scope body
agent return_in_handle() -> integer {
  handle {
    request get_value() => {
      continue 0
    }
  }
  let v = get_value()
  if v == 0 {
    return -1
  }
  v
}

// ── break (handle context) ───────────────────────────────────────

// break from handle scope body
agent break_handle_body() -> integer {
  handle {
    request get_value() => {
      continue 0
    }
  }
  let v = get_value()
  break 100
}

// break from if inside handle
agent break_handle_if() -> integer {
  handle {
    request get_value() => {
      continue 0
    }
  }
  let v = get_value()
  if v == 0 {
    break 999
  }
  v
}

// break from request handler (exits handle)
agent break_from_handler() -> integer {
  handle {
    request get_value() => {
      break 42
    }
  }
  get_value()
}

// ── break (for context) ──────────────────────────────────────────

// break from for body
agent break_for_direct() -> integer | null {
  for (let x of [1, 2, 3, 4, 5]) {
    if x == 3 {
      break x
    }
  }
}

// break from for with then
agent break_for_with_then() -> integer {
  for (let x of [1, 2, 3, 4, 5]) {
    if x == 3 {
      break x * 10
    }
  } then {
    0
  }
}

// break from nested if inside for
agent break_for_nested_if() -> string | null {
  for (let x of [1, 2, 3]) {
    if x > 1 {
      if x == 2 {
        break "found two"
      }
    }
  }
}

// ── continue (handle context) ────────────────────────────────────

// continue with value in request handler
agent continue_handle_value() -> integer {
  handle {
    request get_value() => {
      continue 42
    }
  }
  get_value()
}

// continue with value and state update
agent continue_handle_state() -> integer {
  handle (total: integer = 0) {
    request set_value(v) => {
      continue null with { total = total + v }
    }
  } then (result) {
    total
  }
  set_value(10)
  set_value(20)
  null
}

// ── continue (for context) ───────────────────────────────────────

// continue without state update (just advance)
agent continue_for_bare() -> null {
  for (let x of [1, 2, 3]) {
    continue
  }
}

// continue with state update
agent continue_for_state() -> integer {
  for (let x of [1, 2, 3, 4, 5], var sum: integer = 0) {
    continue with { sum = sum + x }
  } then {
    sum
  }
}

// conditional continue with state
agent continue_for_conditional() -> integer {
  for (let x of [1, 2, 3, 4, 5], var sum: integer = 0) {
    if x > 2 {
      continue with { sum = sum + x }
    }
    continue with { sum = sum }
  } then {
    sum
  }
}

// ── never propagation ────────────────────────────────────────────

// code after return is unreachable (never type)
agent never_after_return() -> integer {
  return 42
}

// code after break in for is unreachable
agent never_after_break() -> integer | null {
  for (let x of [1]) {
    break x
  }
}

// ── then clause variations ───────────────────────────────────────

// handle then clause with return
agent handle_then_return() -> integer {
  handle {
    request get_value() => {
      continue 0
    }
  } then (result) {
    return result + 100
  }
  get_value()
}

// for then clause accessing state
agent for_then_state() -> { sum: integer, count: integer } {
  for (let x of [1, 2, 3],
       var sum: integer = 0,
       var count: integer = 0) {
    continue with { sum = sum + x, count = count + 1 }
  } then {
    { sum = sum, count = count }
  }
}
