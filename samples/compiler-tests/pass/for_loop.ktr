// for_loop.ktr -- for loops, state variables, break/continue, then

// basic for loop
agent basic_for() -> null {
  for (let x of [1, 2, 3]) {
    x
  }
}

// for loop with state accumulator
agent for_sum() -> integer {
  for (let x of [1, 2, 3, 4, 5], var acc: integer = 0) {
    continue with { acc = acc + x }
  } then {
    acc
  }
}

// for loop with break
agent for_find() -> integer | null {
  for (let x of [1, 2, 3, 4, 5]) {
    if x == 3 {
      break x
    }
  }
}

// for loop with break and then
agent for_find_or_default() -> integer {
  for (let x of [1, 2, 3, 4, 5]) {
    if x > 10 {
      break x
    }
  } then {
    0
  }
}

// for loop with continue and state update
agent for_filter_sum() -> integer {
  for (let x of [1, 2, 3, 4, 5], var acc: integer = 0) {
    if x > 2 {
      continue with { acc = acc + x }
    }
  } then {
    acc
  }
}

// for loop with multiple state variables
agent for_multi_state() -> { sum: integer, count: integer } {
  for (let x of [10, 20, 30],
       var sum: integer = 0,
       var count: integer = 0) {
    continue with { sum = sum + x, count = count + 1 }
  } then {
    { sum = sum, count = count }
  }
}

// nested for loops
agent for_nested() -> integer {
  for (let row of [[1, 2], [3, 4]],
       var total: integer = 0) {
    let row_sum = for (let x of row, var s: integer = 0) {
      continue with { s = s + x }
    } then {
      s
    }
    continue with { total = total + row_sum }
  } then {
    total
  }
}
