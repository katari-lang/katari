// nested.ktr -- nested handle/for/par combinations

// requests for testing
request get_item() -> integer
request accumulate(v: integer) -> null

// ── 1. handle 内 for ─────────────────────────────────────────────
// handle scope body 内で for ループを使用
// for 内の break/continue は ForCtx
agent handle_containing_for() -> integer {
  handle {
    request get_item() => {
      continue 0
    }
  }
  let items = [1, 2, 3, 4, 5]
  for (let x of items, var total: integer = 0) {
    continue with { total = total + x }
  } then {
    total
  }
}

// ── 2. for 内 handle ─────────────────────────────────────────────
// for body 内で handle を使用
// handle 内の break は HandleCtx
agent for_containing_handle() -> integer {
  for (let x of [10, 20, 30], var acc: integer = 0) {
    handle {
      request get_item() => {
        break 0
      }
    }
    let item = get_item()
    let new_acc = acc + item + x
    continue with { acc = new_acc }
  } then {
    acc
  }
}

// ── 3. handle 内 handle ──────────────────────────────────────────
// nested handle: 内側の break は内側の handle のみに影響
request get_outer() -> integer
request get_inner() -> string

agent handle_in_handle() -> string {
  handle {
    request get_outer() => {
      break "outer-break"
    }
  }
  let x = get_outer()
  handle {
    request get_inner() => {
      break f"inner-break with outer=${x}"
    }
  }
  get_inner()
}

// ── 4. par 内 handle ─────────────────────────────────────────────
agent par_with_handle() -> array[integer] {
  par [
    {
      handle {
        request get_item() => {
          break 999
        }
      }
      get_item()
    },
    {
      42
    }
  ]
}

// ── 5. par 内 for ────────────────────────────────────────────────
agent par_with_for() -> array[integer] {
  let xs = [1, 2, 3]
  par [
    {
      for (let x of xs, var s: integer = 0) {
        continue with { s = s + x }
      } then {
        s
      }
    },
    {
      for (let x of xs, var p: integer = 1) {
        continue with { p = p * x }
      } then {
        p
      }
    }
  ]
}

// ── 6. 3重ネスト: handle > for > handle ─────────────────────────
request get_seed() -> integer
request notify_result(v: integer) -> null

agent handle_for_handle() -> integer {
  handle {
    request get_seed() => {
      continue 10
    }
  }
  let seed = get_seed()
  for (let x of [1, 2, 3], var total: integer = seed) {
    handle (count: integer = 0) {
      request notify_result(v) => {
        continue null with { count = count + 1 }
      }
    }
    notify_result(x)
    continue with { total = total + x }
  } then {
    total
  }
}

// ── 7. 3重ネスト: for > handle > for ────────────────────────────
agent for_handle_for() -> integer {
  for (let row of [[1, 2], [3, 4]], var grand_total: integer = 0) {
    handle {
      request get_item() => {
        continue 0
      }
    }
    let multiplier = get_item()
    let row_sum = for (let x of row, var s: integer = 0) {
      continue with { s = s + x * multiplier }
    } then {
      s
    }
    continue with { grand_total = grand_total + row_sum }
  } then {
    grand_total
  }
}

// ── 8. par > handle > for ────────────────────────────────────────
agent par_handle_for() -> array[integer] {
  par [
    {
      handle {
        request get_item() => {
          continue 1
        }
      }
      let factor = get_item()
      for (let x of [10, 20, 30], var s: integer = 0) {
        continue with { s = s + x * factor }
      } then {
        s
      }
    },
    {
      100
    }
  ]
}
