// ext.ktr -- 外部サーバー宣言

import types

// ─── Discord サーバー ───────────────────────────────────────────

@"チャンネルを監視し、メッセージ受信ごとに on_message request を発火する"
external agent watch_channel(channel_id: ChannelId) -> null with on_message from "discord:watch_channel"

@"メッセージ受信イベント"
external request on_message(msg: Message) -> null from "discord:on_message"

@"メッセージを送信する"
external agent send_message(
  channel_id: ChannelId @"送信先チャンネルID",
  content: string @"メッセージ本文"
) -> MessageId from "discord:send_message"

@"メッセージに返信する"
external agent reply_to(
  channel_id: ChannelId @"チャンネルID",
  message_id: MessageId @"返信先メッセージID",
  content: string @"返信本文"
) -> MessageId from "discord:reply_to"

@"チャンネルの最新メッセージを取得する"
external agent fetch_messages(
  channel_id: ChannelId @"チャンネルID",
  limit: integer @"取得件数"
) -> array[Message] from "discord:fetch_messages"

// ─── AI サーバー ────────────────────────────────────────────────
@"AIセッションを作成する"
external agent create_session(
  summary_threshold: integer | null @ "要約トリガーの文字数閾値 (null の場合 50000)"
) -> string from "ai:create_session"

@"AIにプロンプトを送信し、ツール呼び出し付きで応答を得る"
external agent ask_ai_with_tools(
  session_id: string @"セッションID",
  system: string @"システムプロンプト",
  prompt: string @"プロンプト",
  tools: array[AgentRef] @"使用可能なツールの配列"
) -> string from "ai:ask_with_tools"

// ─── Cron サーバー ──────────────────────────────────────────────

@"Cron式に基づき定期的にnotify requestを発火する"
external agent schedule(cron_expr: string @"Cron式") -> null with notify from "cron:schedule"

@"定期実行トリガー"
external request notify(time: string @"現在時刻") -> null from "cron:notify"

// ─── Web検索サーバー ────────────────────────────────────────────

@"Webを検索して結果を取得する"
external agent web_search(
  query: string @"検索クエリ"
) -> array[SearchResult] from "websearch:search"

// ─── Sandbox サーバー ────────────────────────────────────────────

@"Docker sandbox を作成する"
external agent create_sandbox() -> string from "sandbox:create"

@"sandbox でコマンドを実行する"
external agent exec_in_sandbox(
  sandbox_id: string @"サンドボックスID",
  command: string @"実行するコマンド"
) -> string from "sandbox:exec"

@"sandbox にファイルを書き込む"
external agent write_file_in_sandbox(
  sandbox_id: string @"サンドボックスID",
  path: string @"ファイルパス",
  content: string @"ファイル内容"
) -> null from "sandbox:write_file"

@"sandbox からファイルを読み込む"
external agent read_file_from_sandbox(
  sandbox_id: string @"サンドボックスID",
  path: string @"ファイルパス"
) -> string from "sandbox:read_file"

@"sandbox を破棄する"
external agent destroy_sandbox(
  sandbox_id: string @"サンドボックスID"
) -> null from "sandbox:destroy"
