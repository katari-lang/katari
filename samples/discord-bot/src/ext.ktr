// ext.ktr -- 外部サーバー宣言

import { ChannelId, MessageId, Message, SearchResult, AgentRef } from types

// ─── Discord サーバー ───────────────────────────────────────────

@"チャンネルを監視し、メッセージ受信ごとに on_message req を発火する"
ext agent watch_channel(@"監視するチャンネルの ID" channel_id: ChannelId) -> null with on_message

@"メッセージ受信イベント"
req on_message(msg: Message) -> null

@"メッセージを送信する"
ext agent send_message(
  @"送信先チャンネル ID" channel_id: ChannelId,
  @"メッセージ本文" content: string
) -> MessageId

@"メッセージに返信する"
ext agent reply_to(
  @"チャンネル ID" channel_id: ChannelId,
  @"返信先メッセージ ID" message_id: MessageId,
  @"返信本文" content: string
) -> MessageId

@"チャンネルの最新メッセージを取得する"
ext agent fetch_messages(
  @"チャンネル ID" channel_id: ChannelId,
  @"取得件数" limit: integer
) -> array[Message]

// ─── AI サーバー ────────────────────────────────────────────────

@"AI セッションを作成する"
ext agent create_session(
  @"要約トリガーの文字数閾値 (null の場合 50000)" summary_threshold: integer | null
) -> string

@"AI にプロンプトを送信し、ツール呼び出し付きで応答を得る"
ext agent ask_ai_with_tools(
  @"セッション ID" session_id: string,
  @"システムプロンプト" system: string,
  @"プロンプト" prompt: string,
  @"使用可能なツールの配列" tools: array[AgentRef]
) -> string

// ─── Cron サーバー ──────────────────────────────────────────────

@"Cron 式に基づき定期的に notify req を発火する"
ext agent schedule(@"Cron 式" cron_expr: string) -> null with notify

@"定期実行トリガー"
req notify(@"現在時刻" time: string) -> null

// ─── Web 検索サーバー ────────────────────────────────────────────

@"Web を検索して結果を取得する"
ext agent web_search(@"検索クエリ" query: string) -> array[SearchResult]

// ─── Sandbox サーバー ────────────────────────────────────────────

@"Docker sandbox を作成する"
ext agent create_sandbox() -> string

@"sandbox でコマンドを実行する"
ext agent exec_in_sandbox(
  @"サンドボックス ID" sandbox_id: string,
  @"実行するコマンド" command: string
) -> string

@"sandbox にファイルを書き込む"
ext agent write_file_in_sandbox(
  @"サンドボックス ID" sandbox_id: string,
  @"ファイルパス" path: string,
  @"ファイル内容" content: string
) -> null

@"sandbox からファイルを読み込む"
ext agent read_file_from_sandbox(
  @"サンドボックス ID" sandbox_id: string,
  @"ファイルパス" path: string
) -> string

@"sandbox を破棄する"
ext agent destroy_sandbox(@"サンドボックス ID" sandbox_id: string) -> null
