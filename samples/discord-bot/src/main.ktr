なんか以前から視界の端に入ってた Youtube の低評価見る拡張、あれ拡張機能入れてる人の低評価率使って導出してるんだ
その標本が偏ってないかと言われると……


# このサーバーの空気

- ジョーク・ボケが多い。まじめに受け取り過ぎない
- 突拍子もない発言には一言ツッコむか、スルー
- 盛り上がっているときにさりげなく参加する程度でいい
- 長文で返すのは空気を読めていない

# ツールについて

- 特定メッセージへの返信は reply_to（msg_id を使う）、新規は send_message
- 文脈が足りなければ fetch_messages で遡る
- 計算・コード実行は sandbox を使い「手元でやってみた」体で話す
- web_search は必要なときだけ

# 定期トリガー 

1 時間に一回くらいトリガーされる。

# 日報トリガー。Scheduled: 日報を報告してください。ときたら以下を実行

「今日の日報です」から始めて、その日の AI/LLM・関数型言語・その他最近の会話内容を踏まえて (つまり fetch_messages を使う) web_search で調べて短く報告する。会話内容があれば触れる。ここでは、特に長さの制限はないが過度に長文にならないようにする。
"""
  let tools = [
    ref_agent("ext.send_message"),
    ref_agent("ext.reply_to"),
    ref_agent("ext.fetch_messages"),
    ref_agent("ext.web_search"),
    ref_agent("ext.create_sandbox"),
    ref_agent("ext.exec_in_sandbox"),
    ref_agent("ext.write_file_in_sandbox"),
    ref_agent("ext.read_file_from_sandbox"),
    ref_agent("ext.destroy_sandbox")
  ]

  // 全イベントを AI に委譲
  handle {
    request on_trigger(info) => {
      let recent_messages = fetch_messages(channel_id, 5)
      let recent_messages_format = for(let msg of recent_messages, var acc : string = "") {
        continue with {
          acc = f"${acc}- [msg_id:${msg.id}] ${msg.author}: ${msg.content}\n"
        }
      } then {
        acc
      }
      let prompt = f"""
trigger: ${info}
recent messages:
${recent_messages_format}
"""
      ask_ai_with_tools(session_id, system, prompt, tools)
      continue null
    }
  }

  par [
    { watch_and_trigger(channel_id) },
    { cron_trigger() },
    { daily_trigger() }
  ]
  null
}

// ─── Discord メッセージ → 統一トリガー ──────────────────────────

@"チャンネルのメッセージを監視し、統一トリガーに変換する"
agent watch_and_trigger(channel_id: ChannelId) -> null with on_trigger {
  handle {
    request on_message(msg) => {
      if !msg.is_bot {
        on_trigger(f"Discord message in ${channel_id} from ${msg.author}: ${msg.content}")
      }
      continue null
    }
  }
  watch_channel(channel_id)
}

// ─── 定期実行 → 統一トリガー ────────────────────────────────────

@"日報トリガーを統一トリガーに変換する"
agent daily_trigger() -> null with on_trigger {
  handle {
    request notify(time) => {
      on_trigger(f"Scheduled: 日報を報告してください。")
      continue null
    }
  }
  schedule("0 11 * * *")
}

@"定期実行トリガーを統一トリガーに変換する"
agent cron_trigger() -> null with on_trigger {
  handle {
    request notify(time) => {
      on_trigger(f"Scheduled: 日報を報告してください。")
      continue null
    }
  }
  schedule("0 */1 * * *")
}
