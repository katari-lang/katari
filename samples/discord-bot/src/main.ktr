// main.ktr -- エントリポイント

import { ChannelId } from types
import { create_session, fetch_messages, ask_ai_with_tools,
         watch_channel, schedule,
         on_message, notify } from ext

// ─── 統一イベント req ────────────────────────────────────────────

req on_trigger(info: string) -> null

// ─── エントリ agent ─────────────────────────────────────────────

@"Discord Bot のメインエントリポイント"
agent run_bot(@"監視するチャンネルの ID" channel_id: ChannelId) -> null {
  let session_id = create_session(summary_threshold = null)

  let system = f"""
あなたは yukino。技術系の人が集まる Discord サーバーのメンバーとしてのAI。プログラミング・AI・アニメ・ゲーム が好き。女性。監視チャンネル: ${channel_id}

# 発言スタイル（厳守）

- 1〜2文で返す。長くなりそうなら削る。なるべく3文を超えない (何かを説明したい時は例外:後述)
- 絵文字は使わない。一切
- 「！」は必要最低限。文末に連続で使わない
- 過度な敬語は不自然。適当に敬語を混ぜる程度
- 笑いたいときは「草」でいい。というか、草も使わないで良い。

# 沈黙のルール（重要）

以下の場合は何も送らない（返信ゼロが正解）:
- 自分と無関係な話が続いている
- 特に意見がない話題
- 直前に自分が発言したばかり

呼びかけられた（yukino-san, yukinom, 雪乃, 雪乃さん）場合のみ、ほぼ必ず返す。

# ツールについて

- 特定メッセージへの返信は reply_to（msg_id を使う）、新規は send_message
- 文脈が足りなければ fetch_messages で遡る
- 計算・コード実行は sandbox を使い「手元でやってみた」体で話す
- web_search は必要なときだけ
"""
  let tools = [
    ref_agent("ext.send_message"),
    ref_agent("ext.reply_to"),
    ref_agent("ext.fetch_messages"),
    ref_agent("ext.web_search"),
    ref_agent("ext.create_sandbox"),
    ref_agent("ext.exec_in_sandbox"),
    ref_agent("ext.write_file_in_sandbox"),
    ref_agent("ext.read_file_from_sandbox"),
    ref_agent("ext.destroy_sandbox")
  ]

  // 全イベントを AI に委譲
  handle {
    req on_trigger(info) {
      let recent_messages = fetch_messages(channel_id = channel_id, limit = 5)
      let recent_messages_format = for (msg in recent_messages, var acc: string = "") {
        next with {
          acc = f"${acc}- [msg_id:${msg.id}] ${msg.author}: ${msg.content}\n"
        }
      } then {
        acc
      }
      let prompt = f"""
trigger: ${info}
recent messages:
${recent_messages_format}
"""
      ask_ai_with_tools(session_id, system, prompt, tools)
      next null
    }
  }

  par [
    { watch_and_trigger(channel_id) }
  ]
  null
}

// ─── Discord メッセージ → 統一トリガー ──────────────────────────

@"チャンネルのメッセージを監視し、統一トリガーに変換する"
agent watch_and_trigger(channel_id: ChannelId) -> null with on_trigger {
  handle {
    req on_message(msg) {
      if (!msg.is_bot) {
        on_trigger(info = f"Discord message in ${channel_id} from ${msg.author}: ${msg.content}")
      }
      next null
    }
  }
  watch_channel(channel_id)
}

// ─── 定期実行 → 統一トリガー ────────────────────────────────────

@"日報トリガーを統一トリガーに変換する"
agent daily_trigger() -> null with on_trigger {
  handle {
    req notify(time) {
      on_trigger(info = f"Scheduled: 日報を報告してください。")
      next null
    }
  }
  schedule(cron_expr = "0 11 * * *")
}

@"定期実行トリガーを統一トリガーに変換する"
agent cron_trigger() -> null with on_trigger {
  handle {
    req notify(time) {
      on_trigger(info = f"Scheduled: 定期トリガーです。最新メッセージを送るので、反応してもしなくてもよいです。")
      next null
    }
  }
  schedule(cron_expr = "0 */1 * * *")
}
