// bot.ktr -- ボットのメインロジック: メッセージ監視と応答

import types
import ext
import ai
import lib.util

// ─── request 定義 ───────────────────────────────────────────────

// ボットの状態管理用 request
request get_history() -> array[Message]
request add_to_history(msg: Message) -> null

// ─── チャンネル監視 ─────────────────────────────────────────────

@"指定チャンネルを監視し、メッセージに応答する"
agent watch_channel(
  channels: array[Channel],
  channel_index: integer
) -> null {
  // handle でメッセージ履歴を管理
  handle (history: array[Message] = []) {
    request get_history() => {
      continue history
    }
    request add_to_history(msg) => {
      // 履歴は最新10件まで保持
      let new_history = append_limited(history, msg, 10)
      continue null with { history = new_history }
    }
  }

  // メッセージを繰り返し取得して処理
  let channel_id = get_channel_id(channels, channel_index)
  let messages = fetch_messages(channel_id, 20)

  for (let msg of messages) {
    // bot自身のメッセージはスキップ
    if !msg.is_bot {
      process_message(msg)
    }
  }
  null
}

// ─── メッセージ処理 ─────────────────────────────────────────────

@"個々のメッセージを処理し、必要に応じて応答する"
agent process_message(msg: Message) -> null with get_history | add_to_history {
  // 履歴に追加
  add_to_history(msg)
  let history = get_history()

  // AI に判断を依頼
  let decision: Action = decide_action(msg, history)

  match decision {
    case { uniq action = "reply" } => {
      let reply_text = generate_reply(msg, history)
      reply_to(msg.channel_id, msg.id, reply_text)
      null
    }
    case { uniq action = "post" } => {
      let post_text = generate_post(msg, history)
      send_message(msg.channel_id, post_text)
      null
    }
    case { uniq action = "search_and_reply" } => {
      let search_results = web_search(msg.content)
      let context = format_search_results(search_results)
      let reply_text = generate_reply_with_context(msg, history, context)
      reply_to(msg.channel_id, msg.id, reply_text)
      null
    }
    case { uniq action = "ignore" } => {
      null
    }
  }
}
