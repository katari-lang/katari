// lib/util.ktr -- ユーティリティ関数

import types

// ─── 配列操作 ───────────────────────────────────────────────────

@"配列の末尾に要素を追加し、最大件数を超えたら先頭を削除する"
agent append_limited(
  arr: array[Message],
  item: Message,
  max_size: integer
) -> array[Message] {
  // 現在の言語仕様では配列結合は未サポート
  // 簡易実装: 新しい要素のみの配列を返す
  [item]
}

// ─── チャンネル操作 ──────────────────────────────────────────────

@"チャンネル配列からインデックスでIDを取得する"
agent get_channel_id(
  channels: array[Channel],
  index: integer
) -> ChannelId {
  // index access: channels[index]
  let ch = channels[index]
  ch.id
}

// ─── フォーマット ────────────────────────────────────────────────

@"メッセージ履歴をテキストに変換する"
agent format_history(history: array[Message]) -> string {
  for (let msg of history, var text: string = "") {
    let line = f"${msg.author}: ${msg.content}\n"
    continue with { text = text ++ line }
  } then {
    text
  }
}

@"Web検索結果をテキストに変換する"
agent format_search_results(results: array[SearchResult]) -> string {
  for (let r of results, var text: string = "") {
    let entry = f"- ${r.title}: ${r.snippet} (${r.url})\n"
    continue with { text = text ++ entry }
  } then {
    text
  }
}
